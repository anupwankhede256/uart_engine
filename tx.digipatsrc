file_format_version 1.1;

timeset time_uart;

pattern tx (TX_PIN)
{
    time_uart X;

    source_start(new_waveform) time_uart X;
    set_loop(reg0) time_uart X;

start: time_uart 0;

    source time_uart D;
    source time_uart D;
    source time_uart D;
    source time_uart D;
    source time_uart D;
    source time_uart D;
    source time_uart D;
    source time_uart D;
    time_uart 1;

    end_loop(start) time_uart X;
    halt time_uart X;
}
